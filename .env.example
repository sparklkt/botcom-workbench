# BotCom Workbench optional configuration

BOTCOM_HOME=$HOME/BotCom
BOTCOM_MEDIA_OPS_ROOT=$HOME/BotCom/media-ops
BOTCOM_WORKBENCH_ROOT=$HOME/BotCom/AI-Workbench
BOTCOM_ADAPTERS_ROOT=$HOME/BotCom/adapters
